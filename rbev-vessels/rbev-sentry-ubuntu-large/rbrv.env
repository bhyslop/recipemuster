# Recipe Bottle Regime Vessel - Sentry Ubuntu Large (Conjuring)

# Core Identity
RBRV_SIGIL=rbev-sentry-ubuntu-large
RBRV_DESCRIPTION="Ubuntu-based sentry image with comprehensive networking tools"

# Vessel Mode
RBRV_VESSEL_MODE=conjure

# Egress Mode
RBRV_EGRESS_MODE=tether

# Tool Image Reliquary
RBRV_RELIQUARY=r260327172456

# Conjuring Configuration
RBRV_CONJURE_DOCKERFILE="${RBRR_VESSEL_DIR}/${RBRV_SIGIL}/Dockerfile"
RBRV_CONJURE_BLDCONTEXT="${RBRR_VESSEL_DIR}/${RBRV_SIGIL}"
RBRV_CONJURE_PLATFORMS="linux/amd64 linux/arm64"

# Base Image Declarations
RBRV_IMAGE_1_ORIGIN=ubuntu:24.04

# eof
RBRV_IMAGE_1_ANCHOR=ubuntu-24.04-186072bba1
