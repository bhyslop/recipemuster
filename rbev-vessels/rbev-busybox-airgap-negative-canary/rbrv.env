# Recipe Bottle Regime Vessel - BusyBox Airgap Negative Canary (Conjuring)
# Designed to FAIL: no anchor, airgap mode — Docker Hub unreachable.
# Permanent regression sentinel for airgap enforcement.

# Core Identity
RBRV_SIGIL=rbev-busybox-airgap-negative-canary
RBRV_DESCRIPTION="Airgap negative canary - designed to fail (no anchor, Docker Hub blocked)"

# Vessel Mode
RBRV_VESSEL_MODE=conjure

# Egress Mode
RBRV_EGRESS_MODE=airgap

# Tool Image Reliquary
RBRV_RELIQUARY=

# Conjuring Configuration
RBRV_CONJURE_DOCKERFILE="${RBRR_VESSEL_DIR}/${RBRV_SIGIL}/Dockerfile"
RBRV_CONJURE_BLDCONTEXT="${RBRR_VESSEL_DIR}/${RBRV_SIGIL}"
RBRV_CONJURE_PLATFORMS="linux/amd64"

# Base Images — intentionally NO anchor (canary tests that airgap blocks Docker Hub)
RBRV_IMAGE_1_ORIGIN=busybox:latest
RBRV_IMAGE_1_ANCHOR=

# eof
