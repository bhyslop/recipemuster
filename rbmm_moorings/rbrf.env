# Recipe Bottle Federation Regime — manor-scoped (org-level) IdP trust.
# Holds the workforce-pool identity and the external OIDC provider the manor is
# affianced to. Org-scoped, NOT depot-scoped: one pool serves every depot under
# the manor (the same principal subject is grantable in each). Carries no
# secrets — every value is a public identifier — so it ships committed.
#
# Seeded to the STANDING SPIKE TRUST (the project's standing test trust, per the
# federation-legs-spike findings). Affiance (manor founding) rewrites these
# values when founding a fresh trust against a real org + IdP tenant.

# Workforce pool identity (org-scoped; one pool serves every depot under the manor).
RBRF_ORG_ID=247899326218
RBRF_WORKFORCE_POOL_ID=spike-office-test
RBRF_PROVIDER_ID=spike-entra

# Workforce pool session duration — the assize cap (900s–43200s). Caps the
# federated token's lifetime; the live window a compearance opens.
RBRF_SESSION_DURATION=3600s

# IdP trust — the external OIDC provider affianced to the manor (here: a free
# Microsoft Entra tenant). The endpoints are explicit fields, not derived from a
# tenant template, so a non-Entra IdP needs no code change — only new values.
RBRF_IDP_ISSUER=https://login.microsoftonline.com/beb3e682-4589-4228-bcf9-27d48c125dbd/v2.0
RBRF_IDP_CLIENT_ID=6d54c87a-e6c4-47d0-81e6-b91fe470ee1c

# Device-flow scope. Must request openid; must NOT request offline_access — a
# refresh token would let a run begin outside a live assize (the human-present
# premise). The regime validator enforces both.
RBRF_IDP_SCOPE="openid profile email"

# Leg-1 device authorization endpoints (RFC 8628): the devicecode request and
# the token-polling endpoint.
RBRF_IDP_DEVICE_ENDPOINT=https://login.microsoftonline.com/beb3e682-4589-4228-bcf9-27d48c125dbd/oauth2/v2.0/devicecode
RBRF_IDP_TOKEN_ENDPOINT=https://login.microsoftonline.com/beb3e682-4589-4228-bcf9-27d48c125dbd/oauth2/v2.0/token

# Workforce provider attribute mapping (affiance writes it into the provider).
# Must map google.subject; here the immutable Entra object id is the subject.
RBRF_ATTRIBUTE_MAPPING="google.subject=assertion.oid"

# eof
