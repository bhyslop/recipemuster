# Recipe Bottle Repository Configuration - Base Values

RBRR_DNS_SERVER=8.8.8.8

# Reference directory containing specs for all vessels: relative to project root
RBRR_VESSEL_DIR=rbev-vessels

# Depot configuration items
RBRR_DEPOT_PROJECT_ID=rbwg-d-demo1025-260304183118
RBRR_GCP_REGION=us-central1
RBRR_GAR_REPOSITORY=rbw-demo1025-repository
RBRR_CBV2_CONNECTION_NAME=rbw-demo1025-gitlab
RBRR_GCB_WORKER_POOL=projects/rbwg-d-demo1025-260304183118/locations/us-central1/workerPools/rbw-demo1025-pool

# Rubric repo
RBRR_RUBRIC_REPO_URL=https://gitlab.com/bhyslop/rb-rubric.git

# Google Cloud Build settings
RBRR_GCB_MACHINE_TYPE=e2-standard-2          # Compute Engine machine type for private pool workerConfig
RBRR_GCB_TIMEOUT=1200s                      # 20 minute timeout
RBRR_GCB_MIN_CONCURRENT_BUILDS=3            # Minimum concurrent builds required; audit and build preflight verify quota headroom

# Secrets directory — contains all credential files (RBRA and RBRO format)
# Credential file paths are derived as kindle constants in rbdc_DerivedConstants.sh
RBRR_SECRETS_DIR=../station-files/secrets

# eof
